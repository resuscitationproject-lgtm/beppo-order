function findOrderBy_(header,value) { var values=sheet_(SHEETS_.ORDERS).getDataRange().getValues();if(values.length<2)return null;var headers=values[0].map(String),index=headers.indexOf(header==="clientRequestId"?"clientRequestId":header);for(var i=values.length-1;i>=1;i--)if(String(values[i][index])===String(value)){var o={};headers.forEach(function(h,j){o[h]=values[i][j];});o._row=i+1;return o;}return null; }
