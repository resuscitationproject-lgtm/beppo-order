    record.sheet.getRange(record.row,4).setValue(Number(record.values[3])+body.quantity);record.values[3]=Number(record.values[3])+body.quantity;var remaining=recalculateBusinessRow_(record);slot.sheet.getRange(slot.row,4).setValue(slot.current+1);decrementToppingStock_(priced.toppings,body.quantity);
    var order={orderNumber:orderNumber,pickupTime:body.pickupTime,customerName:body.customerName,phone:body.phone,quantity:body.quantity,menuName:priced.menu.name,spice:body.spice,vegan:body.vegan,toppings:priced.toppings.map(function(x){return x.name;}),desserts:priced.desserts.map(function(x){return x.name;}),drinks:priced.drinks.map(function(x){return x.name;}),total:priced.total,status:"受付済み",orderedAt:Utilities.formatDate(now,settings_().TIMEZONE||"Asia/Tokyo","HH:mm"),source:body.source,notes:body.notes,allergies:body.allergies};result={order:order,remaining:remaining};
