function publicOrder_(r) { return{orderNumber:r["注文番号"],pickupTime:r["受取時間"],menuName:r["商品名"],quantity:Number(r["数量"]),spice:r["辛さ"],vegan:r["ビーガン対応"]==="希望",toppings:splitItems_(r["トッピング"]),desserts:splitItems_(r["デザート"]),drinks:splitItems_(r["ドリンク"]),total:Number(r["合計金額"]),status:r["注文ステータス"]}; }
