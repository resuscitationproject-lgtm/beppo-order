}
function decrementToppingStock_(selected,quantity){selected.filter(function(x){return x.limited;}).forEach(function(item){var sheet=sheet_(SHEETS_.TOPPINGS),values=sheet.getDataRange().getValues();for(var i=1;i<values.length;i++)if(String(values[i][0])===item.id){sheet.getRange(i+1,6).setValue(Math.max(0,Number(values[i][5])-quantity));}});}
