function nextOrderNumber_() { var prefix="B"+Utilities.formatDate(new Date(),settings_().TIMEZONE||"Asia/Tokyo","yyMMdd")+"-",rows=rowsAsObjects_(SHEETS_.ORDERS),max=0;rows.forEach(function(r){var n=String(r["注文番号"]||"");if(n.indexOf(prefix)===0)max=Math.max(max,Number(n.slice(-3))||0);});return prefix+("00"+(max+1)).slice(-3); }
